# Copy to ``.env`` and adjust. All variables are required; the app has no in-code defaults.

APP_NAME=event-platform-gateway-api
APP_VERSION=0.1.0
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO
# Bind address for uvicorn (use 127.0.0.1 locally; Docker Compose overrides to 0.0.0.0)
UVICORN_HOST=127.0.0.1

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

RABBITMQ_EXCHANGE=events.topic
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_BOOTSTRAP_QUEUE=events.audit.bootstrap
RABBITMQ_BOOTSTRAP_BINDING_KEY=#

# Management HTTP API — used by /observability/broker endpoint
# Local dev: http://localhost:15672  |  Docker Compose: http://rabbitmq:15672
RABBITMQ_HTTP_API_URL=http://localhost:15672
RABBITMQ_HTTP_API_USER=admin
RABBITMQ_HTTP_API_PASSWORD=admin
# Comma-separated list of queues to include in queue lag stats
RABBITMQ_MONITORED_QUEUES=events.created,events.dlq

# Docker Compose only: must match ``EVENT_PLATFORM_NETWORK_NAME`` in event-platform-infra ``.env``
EVENT_PLATFORM_NETWORK_NAME=event-platform-net
